# Binaries for programs and plugins
*.exe
*.exe~
*.dll
*.so
*.dylib
bin/

# Test binary, built with `go test -c`
*.test

# Output of the go coverage tool, specifically when used with LiteIDE
*.out

# Dependency directories (since you are using go mod, you don't commit vendor usually)
vendor/

# Go workspace file
go.work
go.work.sum

# Environment Variables
.env
.env.local
